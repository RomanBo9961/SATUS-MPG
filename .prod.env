NODE_ENV="prod"

# Debe coincidir con el nombre del servicio en compose.prod
MONGO_HOST="mongodb-prod"
MONGO_PORT=27017
MONGO_USERNAME="prod_user"
MONGO_PASSWORD="[TU_PASSWORD_SUPER_SEGURO_AQUI]"
MONGO_NAME="satus_prod_db"
MONGO_CONNECTION=mongodb

JWT_SECRET=[TU_FIRMA_DIGITAL_PROD_AQUI]
JWT_EXPIRES_IN=1h

VT_API_KEY=[TU_LLAVE_PROD_AQUI]
AI_API_KEY=[TU_LLAVE_IA_PROD_AQUI]
